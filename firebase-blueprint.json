{
  "entities": {
    "BlogSite": {
      "title": "Blog Site",
      "description": "Represents a single website created by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "blogData": { "type": "array" },
        "theme": { "type": "object" },
        "socials": { "type": "array" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "blogData", "theme", "socials", "updatedAt"]
    }
  },
  "firestore": {
    "/sites/{siteId}": {
      "schema": "BlogSite",
      "description": "A collection of blog sites keyed by their unique ID."
    }
  }
}
