rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Site ID validation helper
    function isValidSiteId(siteId) {
      return siteId is string && siteId.size() <= 128 && siteId.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema validation for BlogSite
    function isValidBlogSite(data) {
      return data.keys().hasAll(['id', 'name', 'blogData', 'theme', 'socials', 'updatedAt'])
        && data.id is string
        && data.name is string
        && data.blogData is list
        && data.theme is map
        && data.socials is list
        && data.updatedAt is number
        && (!('isActive' in data) || data.isActive is bool)
        && (!('password' in data) || data.password is string);
    }

    match /sites/{siteId} {
      // Allow anybody to read a site if they have the ID (for shared links)
      allow get: if isValidSiteId(siteId);
      
      // List is restricted for security (prevent scraping)
      allow list: if false; 

      // Allow anybody to create or update a site for now (simple multi-user logic)
      allow create: if isValidSiteId(siteId) && isValidBlogSite(request.resource.data);
      allow update: if isValidSiteId(siteId) && isValidBlogSite(request.resource.data);
    }
  }
}
